/*
========================================================================================
    Kinnex IsoSeq Pipeline — nextflow.config
========================================================================================
*/

// ─── Default Parameters ───────────────────────────────────────────────────────
def projectDir = "/data2/lackey_lab/DownloadedSequenceData/austin/chick/chick_test"

params {

    // ── Input/Output ──────────────────────────────────────────────────────────
    bam_dir        = "${projectDir}/data"
    outdir         = "${projectDir}/results"

    // ── Reference files (place in chick/ref/) ────────────────────────────────
    ref_fasta      = "${projectDir}/ref/galGal6.fa"
    ref_gtf        = "${projectDir}/ref/galGal6.ncbiRefSeq.gtf"

    // ── Primer / adapter FASTA files (place in chick/ref/ or root) ───────────
    mas16_primers  = "${projectDir}/ref/mas16_primers.fasta"
    isoseq_primers = "${projectDir}/ref/IsoSeq_v2_primers_12.fasta"

    // ── Tool paths ────────────────────────────────────────────────────────────
    sqanti3_dir    = "${projectDir}/bin/sqanti3"

    // ── Per-step thread counts (override via --skera_threads etc.) ────────────
    skera_threads   = 24
    lima_threads    = 24
    refine_threads  = 32
    cluster_threads = 32
    index_threads   = 16
    align_threads   = 32
    collapse_threads= 32
    pigeon_threads  = 32
    pigeon_report_threads = 8
    sqanti3_threads = 32

    // ── Pipeline control ─────────────────────────────────────────────────────
    help           = false
}

// ─── Process Defaults ─────────────────────────────────────────────────────────
process {
    errorStrategy  = 'retry'
    maxRetries     = 2
    cache          = 'lenient'

    // Label-based resource allocation (labels set in each module)
    withLabel: 'small' {
        cpus   = 8
        memory = '16.GB'
        time   = '2.h'
    }
    withLabel: 'medium' {
        cpus   = 24
        memory = '64.GB'
        time   = '12.h'
    }
    withLabel: 'large' {
        cpus   = 32
        memory = '128.GB'
        time   = '24.h'
    }
    withLabel: 'xlarge' {
        cpus   = 32
        memory = '256.GB'
        time   = '48.h'
    }
}

// ─── Execution Profiles ───────────────────────────────────────────────────────
profiles {

    // ── Standard (local) ──────────────────────────────────────────────────────
    standard {
        process.executor = 'local'
    }

    // ── SLURM / HPC ───────────────────────────────────────────────────────────
    slurm {
        process.executor       = 'slurm'
        process.queue          = 'defq'        // change to your cluster partition
        process.clusterOptions = '--account=your_account'  // change or remove
        executor {
            queueSize    = 50
            pollInterval = '30 sec'
        }
    }

    // ── Conda environment ─────────────────────────────────────────────────────
    conda {
        conda.enabled = true
        process {
            withLabel: 'isoseq' { conda = "bioconda::isoseq bioconda::pbskera bioconda::lima bioconda::pbmm2 bioconda::pbpigeon" }
            withLabel: 'sqanti3' { conda = "${projectDir}/envs/SQANTI3.conda_env.yml" }
        }
    }

    // ── Docker (optional) ────────────────────────────────────────────────────
    docker {
        docker.enabled = true
    }
}

// ─── Nextflow Tower / reporting ───────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}

// ─── Manifest ─────────────────────────────────────────────────────────────────
manifest {
    name            = 'kinnex-isoseq-pipeline'
    author          = 'Your Name'
    description     = 'PacBio Kinnex RNA-seq full-length transcript processing pipeline'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}
